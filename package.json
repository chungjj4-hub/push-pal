{
  "name": "pushpal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --env-file=../.env --watch index.js",
    "dev:client": "cd client && npm run dev",
    "seed:demo": "node server/scripts/seed-demo.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
