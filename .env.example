# Anthropic
ANTHROPIC_API_KEY=

# WHOOP OAuth2 (register at https://developer.whoop.com)
# Set redirect URI to: http://localhost:3001/whoop/callback
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3001/whoop/callback

# Strava OAuth2 (register at https://www.strava.com/settings/api)
# Set Authorization Callback Domain to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Server
PORT=3001
CLIENT_PORT=5173

# Demo mode — set to true to run entirely on seeded data (data/demo.db),
# with no live WHOOP/Strava OAuth and no live Anthropic calls (the AI coach
# uses realistic canned responses instead). See `npm run seed:demo`.
# Anthropic/WHOOP/Strava keys above aren't required when this is true.
DEMO_MODE=false
